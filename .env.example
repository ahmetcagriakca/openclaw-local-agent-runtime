# Vezir Platform — Environment Variables
# Copy to .env and customize. Do NOT commit .env to git.

# WMCP (Windows MCP Proxy) — port 8001
OC_MCP_BASE_URL=http://localhost:8001
OC_MCP_API_KEY=change-me-in-production

# Vezir API — port 8003
VEZIR_API_PORT=8003
VEZIR_API_HOST=127.0.0.1

# User
OC_USER_ID=your-user-id-here

# Telegram Bot
OC_TELEGRAM_BOT_TOKEN=your-bot-token-here
OC_TELEGRAM_CHAT_ID=your-chat-id-here

# LLM Providers
OPENAI_API_KEY=your-openai-key
ANTHROPIC_API_KEY=your-anthropic-key

# Azure OpenAI — Primary Provider (D-148)
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
AZURE_OPENAI_API_KEY=<your-azure-api-key>
AZURE_OPENAI_DEPLOYMENT=<deployment-name>
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Auth — D-117 + S84 SSO/RBAC
VEZIR_AUTH_BYPASS=1                     # Set to 0 in production
VEZIR_SSO_ENABLED=0                     # Set to 1 to enable OAuth/SSO
VEZIR_OAUTH_PROVIDER=github             # github or generic
VEZIR_OAUTH_CLIENT_ID=                  # GitHub OAuth App client ID
VEZIR_OAUTH_CLIENT_SECRET=              # GitHub OAuth App client secret
VEZIR_OAUTH_REDIRECT_URI=http://localhost:4000/auth/callback
VEZIR_JWT_SECRET=                       # Auto-generated if empty
VEZIR_DEFAULT_ROLE=viewer               # Default role for new OAuth users

# Azure APIM — GPT Review Pipeline
APIM_ENDPOINT=https://<apim-name>.azure-api.net/<path>
APIM_KEY=<subscription-key>
APIM_MODEL=gpt-5.3-codex-cagri
