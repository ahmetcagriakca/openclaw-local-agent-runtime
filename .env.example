# Vezir Platform — Environment Variables
# Copy to .env and customize. Do NOT commit .env to git.

# WMCP (Windows MCP Proxy) — port 8001
OC_MCP_BASE_URL=http://localhost:8001
OC_MCP_API_KEY=change-me-in-production

# Vezir API — port 8003
VEZIR_API_PORT=8003
VEZIR_API_HOST=127.0.0.1

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_ALLOWED_CHAT_ID=your-chat-id-here

# LLM Providers
OPENAI_API_KEY=your-openai-key
ANTHROPIC_API_KEY=your-anthropic-key
