# ============================================================
# Vezir API — Production Multi-Stage Dockerfile
# ============================================================
# Stage 1: Install dependencies
# Stage 2: Runtime (slim, non-root, minimal)
# Target: <200MB
# ============================================================

# --- Stage 1: Builder ---
FROM python:3.12-slim AS builder

WORKDIR /build

COPY agent/requirements.txt /build/requirements.txt
RUN pip install --no-cache-dir --prefix=/install -r requirements.txt

# --- Stage 2: Runtime ---
FROM python:3.12-slim AS runtime

LABEL maintainer="AKCA <ahmetcagriakca@gmail.com>"
LABEL description="Vezir Platform API — Production Image"

# Security: non-root user
RUN groupadd --gid 1000 vezir \
    && useradd --uid 1000 --gid vezir --shell /bin/bash --create-home vezir

WORKDIR /app

# Copy installed packages from builder
COPY --from=builder /install /usr/local

# Copy application code
COPY agent/ /app/agent/
COPY config/ /app/config/

# Create runtime directories (owned by vezir)
RUN mkdir -p /app/agent/missions /app/agent/approvals /app/agent/logs /app/data \
    && echo '{"autoGenerated":true,"capabilities":{}}' > /app/agent/capabilities.json \
    && echo '[]' > /app/agent/services.json \
    && touch /app/agent/telemetry.jsonl \
    && chown -R vezir:vezir /app

# Remove test directories if they leaked through
RUN rm -rf /app/agent/tests /app/agent/__pycache__

# Environment
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    EVENTBUS_ENABLED=true

EXPOSE 8003

HEALTHCHECK --interval=15s --timeout=5s --start-period=20s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8003/api/v1/health')" || exit 1

# Run as non-root
USER vezir

WORKDIR /app/agent

CMD ["python", "-m", "uvicorn", "api.server:app", "--host", "0.0.0.0", "--port", "8003", "--workers", "2"]
