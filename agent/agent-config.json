{
  "defaultAgent": "azure-general",
  "agents": {
    "azure-general": {
      "provider": "azure-openai",
      "model": "gpt-5.3-codex-cagri",
      "endpointEnv": "AZURE_OPENAI_ENDPOINT",
      "apiKeyEnv": "AZURE_OPENAI_API_KEY",
      "apiVersion": "2025-04-01-preview",
      "maxTokens": 4096,
      "maxTurns": 10,
      "timeoutSeconds": 120,
      "enabled": true
    },
    "gpt-general": {
      "provider": "gpt",
      "model": "gpt-4o",
      "apiKeyEnv": "OPENAI_API_KEY",
      "maxTokens": 4096,
      "maxTurns": 10,
      "timeoutSeconds": 120,
      "enabled": true
    },
    "claude-general": {
      "provider": "claude",
      "model": "claude-sonnet-4-20250514",
      "apiKeyEnv": "ANTHROPIC_API_KEY",
      "maxTokens": 4096,
      "maxTurns": 10,
      "timeoutSeconds": 120,
      "enabled": true
    },
    "ollama-general": {
      "provider": "ollama",
      "model": "qwen2.5:7b",
      "baseUrl": "http://localhost:11434",
      "maxTokens": 4096,
      "maxTurns": 10,
      "timeoutSeconds": 180,
      "enabled": true
    },
    "mock-general": {
      "provider": "mock",
      "model": "mock-v1",
      "maxTokens": 4096,
      "maxTurns": 10,
      "timeoutSeconds": 30,
      "enabled": true
    }
  }
}