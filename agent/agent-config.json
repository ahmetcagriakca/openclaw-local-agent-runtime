{
  "defaultAgent": "gpt-general",
  "agents": {
    "gpt-general": {
      "provider": "gpt",
      "model": "gpt-4o",
      "apiKeyEnv": "OPENAI_API_KEY",
      "maxTokens": 4096,
      "maxTurns": 10,
      "timeoutSeconds": 120,
      "enabled": true
    },
    "claude-general": {
      "provider": "claude",
      "model": "claude-sonnet-4-20250514",
      "apiKeyEnv": "ANTHROPIC_API_KEY",
      "maxTokens": 4096,
      "maxTurns": 10,
      "timeoutSeconds": 120,
      "enabled": true
    },
    "ollama-general": {
      "provider": "ollama",
      "model": "qwen2.5:7b",
      "baseUrl": "http://localhost:11434",
      "maxTokens": 4096,
      "maxTurns": 10,
      "timeoutSeconds": 180,
      "enabled": true
    }
  }
}