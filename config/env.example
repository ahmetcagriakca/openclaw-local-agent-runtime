# Required environment variables for openclaw-local-agent-runtime
# Copy this to your environment and fill in real values.
# Do NOT commit actual values to the repo.

# Telegram bot token (required for OpenClaw Telegram channel)
OC_TELEGRAM_BOT_TOKEN=

# Bridge audit log path (optional, default: bridge/logs/bridge-audit.jsonl)
# OC_BRIDGE_AUDIT_LOG=

# WMCP server base URL (optional, default: http://localhost:8001)
# OC_MCP_BASE_URL=
