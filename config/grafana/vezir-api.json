{
  "dashboard": {
    "id": null,
    "uid": "vezir-api",
    "title": "Vezir — API & Infrastructure",
    "tags": ["vezir", "api", "infrastructure"],
    "timezone": "browser",
    "refresh": "30s",
    "schemaVersion": 39,
    "panels": [
      {
        "id": 1,
        "title": "API Request Rate",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "rate(vezir_http_requests_total[5m]) * 60",
            "legendFormat": "{{method}} {{path}} {{status}}"
          }
        ]
      },
      {
        "id": 2,
        "title": "API Latency (p50/p95/p99)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(vezir_http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, rate(vezir_http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(vezir_http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "p99"
          }
        ]
      },
      {
        "id": 3,
        "title": "HTTP Error Rate",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "rate(vezir_http_requests_total{status=~\"4..|5..\"}[5m]) * 60",
            "legendFormat": "{{status}} {{path}}"
          }
        ]
      },
      {
        "id": 4,
        "title": "SSE Active Connections",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "vezir_sse_connections_active",
            "legendFormat": "Active SSE"
          }
        ]
      },
      {
        "id": 5,
        "title": "DLQ Depth",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 8},
        "targets": [
          {
            "expr": "vezir_dlq_entries_total",
            "legendFormat": "DLQ Entries"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 5, "color": "yellow"},
                {"value": 20, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "title": "Total Endpoints",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 12},
        "targets": [
          {
            "expr": "vezir_api_endpoints_total",
            "legendFormat": "Endpoints"
          }
        ]
      }
    ]
  },
  "overwrite": true
}
