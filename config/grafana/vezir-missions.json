{
  "dashboard": {
    "id": null,
    "uid": "vezir-missions",
    "title": "Vezir — Mission Overview",
    "tags": ["vezir", "missions"],
    "timezone": "browser",
    "refresh": "30s",
    "schemaVersion": 39,
    "panels": [
      {
        "id": 1,
        "title": "Missions by Status",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "sum by (status) (vezir_missions_total)",
            "legendFormat": "{{status}}"
          }
        ]
      },
      {
        "id": 2,
        "title": "Mission Throughput (per minute)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 16, "x": 8, "y": 0},
        "targets": [
          {
            "expr": "rate(vezir_missions_total[5m]) * 60",
            "legendFormat": "{{status}}"
          }
        ]
      },
      {
        "id": 3,
        "title": "Mission Duration (p50/p95/p99)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(vezir_mission_duration_seconds_bucket[5m]))",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, rate(vezir_mission_duration_seconds_bucket[5m]))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(vezir_mission_duration_seconds_bucket[5m]))",
            "legendFormat": "p99"
          }
        ]
      },
      {
        "id": 4,
        "title": "Active Missions",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "vezir_missions_active",
            "legendFormat": "Active"
          }
        ]
      },
      {
        "id": 5,
        "title": "Failed Missions (24h)",
        "type": "stat",
        "gridPos": {"h": 4, "w": 6, "x": 18, "y": 8},
        "targets": [
          {
            "expr": "increase(vezir_missions_total{status=\"failed\"}[24h])",
            "legendFormat": "Failed"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 1, "color": "yellow"},
                {"value": 5, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "title": "Mission Stage Breakdown",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
        "targets": [
          {
            "expr": "sum by (stage) (vezir_stage_duration_seconds_sum)",
            "legendFormat": "{{stage}}"
          }
        ]
      }
    ]
  },
  "overwrite": true
}
