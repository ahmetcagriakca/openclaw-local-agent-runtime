#!/usr/bin/env bash
# WSL wrapper for oc-approve — approve/deny agent tool calls
# Usage: oc-approve approve apv-XXX
#        oc-approve deny apv-XXX
#        oc-approve list

SCRIPT="C:\\Users\\AKCA\\oc\\bin\\oc-approve.py"

# Find Windows Python
for p in \
    "/mnt/c/Users/AKCA/AppData/Local/Python/pythoncore-3.14-64/python.exe" \
    "/mnt/c/Users/AKCA/AppData/Local/Programs/Python/Python314/python.exe" \
    "/mnt/c/Users/AKCA/AppData/Local/Programs/Python/Python312/python.exe"; do
    if [ -x "$p" ]; then
        PYTHON="$p"
        break
    fi
done
PYTHON="${PYTHON:-python.exe}"

exec "$PYTHON" "$SCRIPT" "$@"
