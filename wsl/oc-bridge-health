#!/usr/bin/env python3
"""oc-bridge-health - Check runtime health through the frozen Bridge contract."""
import json, os, subprocess, sys, time
user_id = sys.argv[1] if len(sys.argv) > 1 else "8654710624"
req = json.dumps({
    "operation": "get_health",
    "source": "telegram",
    "sourceUserId": user_id,
    "requestId": f"tg-{int(time.time())}-{os.getpid()}",
})
r = subprocess.run(["/home/akca/bin/oc-bridge-call", req], capture_output=False)
sys.exit(r.returncode)
